    "#| echo: false\n",
    "#| fig-align: center\n",
    "import pandas as pd\n",
    "import sqlite3\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.cm as cm\n",
    "\n",
    "conn = sqlite3.connect('./data.db')\n",
    "query = \"\"\"\n",
    "SELECT title, CAST(strftime('%Y', release_date) AS INTEGER) AS year, total_sales \n",
    "FROM video_games \n",
    "WHERE release_date IS NOT NULL AND total_sales IS NOT NULL\n",
    "\"\"\"\n",
    "df = pd.read_sql_query(query, conn)\n",
    "conn.close()\n",
    "\n",
    "# Préparation des données : Top 1 par an entre 1999 et 2022 (exclusion 2023/2024)\n",
    "df = df[(df['year'] >= 1999) & (df['year'] <= 2022)]\n",
    "top_sales = df.sort_values(['year', 'total_sales'], ascending=[True, False]).groupby('year').head(1)\n",
    "\n",
    "plt.figure(figsize=(10, 7))\n",
    "\n",
    "# Création d'un dégradé de couleur basé sur les ventes\n",
    "norm = plt.Normalize(top_sales['total_sales'].min(), top_sales['total_sales'].max())\n",
    "colors = cm.get_cmap('YlOrRd')(norm(top_sales['total_sales'])) # Dégradé Jaune à Rouge\n",
    "\n",
    "bars = plt.barh(top_sales['year'].astype(str), top_sales['total_sales'], color=colors, edgecolor='grey', alpha=0.8)\n",
    "\n",
    "# Ajout des noms des jeux sur les barres\n",
    "for i, bar in enumerate(bars):\n",
    "    width = bar.get_width()\n",
    "    game_title = top_sales.iloc[i]['title']\n",
    "    plt.text(width + 0.5, bar.get_y() + bar.get_height()/2, \n",
    "             f\"{game_title} ({width:.1f}M)\", \n",
    "             va='center', fontsize=7, color='#2c3e50', fontweight='bold')\n",
    "\n",
    "plt.title('Jeux les plus vendus par année (1999-2022)', fontsize=14)\n",
    "plt.xlabel('Ventes mondiales (Millions d\\'unités)', fontsize=10)\n",
    "plt.gca().invert_yaxis() # 1999 en haut\n",
    "plt.xticks(fontsize=8)\n",
    "plt.yticks(fontsize=8)\n",
    "plt.grid(axis='x', linestyle='--', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
