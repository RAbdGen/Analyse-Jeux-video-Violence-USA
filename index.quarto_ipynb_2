        "#| echo: false\n",
        "#| fig-align: center\n",
        "import pandas as pd\n",
        "import sqlite3\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "conn = sqlite3.connect('./data.db')\n",
        "query = \"\"\"\n",
        "SELECT year, COUNT(*) AS shooting_count\n",
        "FROM school_shootings\n",
        "WHERE year IS NOT NULL\n",
        "GROUP BY year\n",
        "ORDER BY year ASC\n",
        "\"\"\"\n",
        "df = pd.read_sql_query(query, conn)\n",
        "conn.close()\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.bar(df['year'].astype(str), df['shooting_count'], color='orange', edgecolor='black')\n",
        "plt.title('Nombre de tueries en milieu scolaire par année (USA)')\n",
        "plt.xticks(rotation=45, fontsize=8)\n",
        "plt.show()"
