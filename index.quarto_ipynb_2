      "source": [
        "#| echo: false\n",
        "#| fig-align: center\n",
        "import pandas as pd\n",
        "import sqlite3\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "conn = sqlite3.connect('./data.db')\n",
        "query = \"\"\"\n",
        "SELECT CAST(strftime('%Y', release_date) AS INTEGER) AS year, MAX(total_sales) AS top_game_sales\n",
        "FROM video_games \n",
        "WHERE release_date IS NOT NULL AND total_sales IS NOT NULL\n",
        "GROUP BY year\n",
        "\"\"\"\n",
        "df_vg = pd.read_sql_query(query, conn)\n",
        "conn.close()\n",
        "\n",
        "df_vg = df_vg[(df_vg['year'] >= 1999) & (df_vg['year'] <= 2024)]\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.plot(df_vg['year'], df_vg['top_game_sales'], marker='o', color='tab:blue')\n",
        "plt.title('Ventes du record de l\\'année (Millions)')\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.show()"
      ],
