    "import pandas as pd\n",
    "import sqlite3\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "plt.style.use('ggplot') \n",
    "conn = sqlite3.connect('./data.db')\n",
    "query = \"SELECT year, COUNT(*) AS shooting_count FROM school_shootings WHERE year IS NOT NULL GROUP BY year ORDER BY year ASC\"\n",
    "df = pd.read_sql_query(query, conn)\n",
    "conn.close()\n",
    "\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.bar(df['year'].astype(str), df['shooting_count'], color='#e67e22', alpha=0.8)\n",
    "plt.title('Nombre de tueries par année', fontsize=14)\n",
    "plt.xticks(rotation=45, fontsize=8)\n",
    "plt.tight_layout()\n",
    "plt.show()"
